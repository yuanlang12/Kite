{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; bunx biome check --write \"$f\" 2>/dev/null || true; }"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun test 2>&1 || true",
            "timeout": 30,
            "statusMessage": "Running tests..."
          }
        ]
      }
    ]
  }
}
