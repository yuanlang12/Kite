# Claude project directory to watch and inject messages into
# Defaults to current working directory
CLAUDE_PROJECT_PATH=/Users/you/your-project

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated Telegram user IDs allowed to use the bot. Leave empty to allow all.
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# ── Feishu / Lark ─────────────────────────────────────────────────────────────
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret
# Comma-separated Feishu user IDs allowed to use the bot. Leave empty to allow all.
FEISHU_ALLOWED_USER_IDS=

# ── Optional ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
